{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Streamlit: Current File (venv)",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "${file}"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}\\venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Streamlit: 3_chatbot.py (venv)",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "${workspaceFolder}\\3_chatbot.py"
      ],
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}\\venv\\Scripts\\python.exe",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Python: Current File (venv)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}\\venv\\Scripts\\python.exe"
    },
    {
      "name": "Python: example_chunking.py (venv)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\example_chunking.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}\\venv\\Scripts\\python.exe"
    }
  ]
}
